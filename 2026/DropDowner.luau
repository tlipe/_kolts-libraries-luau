--!optimize 2

--[[
	Tutorial (Generated by AI):

ScreenGui (MainGui)
├── DropdownsMain (Folder)
│   ├── Menu (TextButton)
│   ├── Config (TextButton)
│   └── Perfil (TextButton)
│
└── DropdownsContents (Folder)
    ├── Menu (Folder)
    │   ├── Option_1 (TextButton)
    │   ├── Option_2 (TextButton)
    │   └── Option_3 (TextButton)
    │
    ├── Config (Folder)
    │   ├── Config_1 (TextButton)
    │   └── Config_2 (TextButton)
    │
    └── Perfil (Folder)
        ├── Item_1 (TextButton)
        ├── Item_2 (TextButton)
        ├── Item_3 (TextButton)
        └── Item_4 (TextButton)

]]

local DropDowner = {}
DropDowner.__index = DropDowner

local TweenService = game:GetService("TweenService")

local tween_config = TweenInfo.new(0.25, Enum.EasingStyle.Quint, Enum.EasingDirection.Out)
local tween_close = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
local auto_close_time = 4

local min_main_zindex = 2
local min_content_zindex = 1

function DropDowner.dropdown(mainFolder: Folder, contentsFolder: Folder, autoClose: boolean?)
	local self = setmetatable({}, DropDowner)

	self._mainFolder = mainFolder
	self._contentsFolder = contentsFolder
	self._autoClose = autoClose or false

	self._connections = {}
	self._dropdownData = {}
	self._activeClones = {}

	return self
end

function DropDowner:Start()
	for _, mainButton in self._mainFolder:GetChildren() do
		if mainButton:IsA("GuiButton") then
			self:_ensureMainZIndex(mainButton)
			self:_setupButton(mainButton)
		end
	end

	return self
end

function DropDowner:_ensureMainZIndex(mainButton)
	if mainButton.ZIndex < min_main_zindex then
		mainButton.ZIndex = min_main_zindex
	end

	for _, child in mainButton:GetChildren() do
		if child:IsA("GuiObject") then
			self:_setChildZIndex(child, mainButton.ZIndex)
		end
	end
end

function DropDowner:_setChildZIndex(element, parentZIndex)
	if element.ZIndex < parentZIndex then
		element.ZIndex = parentZIndex
	end

	for _, child in element:GetChildren() do
		if child:IsA("GuiObject") then
			self:_setChildZIndex(child, parentZIndex)
		end
	end
end

function DropDowner:_getContentZIndex(mainButton)
	local mainZIndex = mainButton.ZIndex
	local contentZIndex = mainZIndex - 1

	if contentZIndex < min_content_zindex then
		contentZIndex = min_content_zindex
		mainButton.ZIndex = min_main_zindex
	end

	return contentZIndex
end

function DropDowner:_applyZIndexToClone(clone, zIndex)
	clone.ZIndex = zIndex

	for _, child in clone:GetChildren() do
		if child:IsA("GuiObject") then
			self:_applyZIndexToClone(child, zIndex)
		end
	end
end

function DropDowner:_setupButton(mainButton)
	local contentFolder = self._contentsFolder:FindFirstChild(mainButton.Name)
	if not contentFolder then return end

	local sortedButtons = self:_getSortedButtons(contentFolder)

	self._dropdownData[mainButton] = {
		buttons = sortedButtons,
		isOpen = false,
		clones = {}
	}

	local clickConnection = mainButton.MouseButton1Click:Connect(function()
		self:_toggleDropdown(mainButton)
	end)

	table.insert(self._connections, clickConnection)
end

function DropDowner:_getSortedButtons(folder)
	local buttonList = {}

	for _, child in folder:GetChildren() do
		if child:IsA("GuiButton") then
			local numberMatch = child.Name:match("_(%d+)$")
			local orderNum = tonumber(numberMatch) or 0
			table.insert(buttonList, {instance = child, order = orderNum})
		end
	end

	table.sort(buttonList, function(a, b)
		return a.order < b.order
	end)

	local result = {}
	for _, data in buttonList do
		table.insert(result, data.instance)
	end

	return result
end

function DropDowner:_toggleDropdown(mainButton)
	local data = self._dropdownData[mainButton]
	if not data then return end

	if data.isOpen then
		self:_closeDropdown(mainButton)
	else
		self:_closeAllDropdowns()
		self:_openDropdown(mainButton)
	end
end

function DropDowner:_openDropdown(mainButton)
	local data = self._dropdownData[mainButton]
	if not data then return end

	data.isOpen = true

	local parentContainer = mainButton.Parent
	local mainPosition = mainButton.Position
	local mainSize = mainButton.Size
	local contentZIndex = self:_getContentZIndex(mainButton)

	for index, originalButton in data.buttons do
		local clone = originalButton:Clone()
		clone.Name = `{originalButton.Name}_Dropdown`
		clone.Visible = true
		clone.Parent = parentContainer

		self:_applyZIndexToClone(clone, contentZIndex)

		local targetYScale = mainPosition.Y.Scale + (mainSize.Y.Scale * index)
		local targetYOffset = mainPosition.Y.Offset + (mainSize.Y.Offset * index)

		local startPosition = UDim2.new(
			mainPosition.X.Scale,
			mainPosition.X.Offset,
			mainPosition.Y.Scale,
			mainPosition.Y.Offset
		)

		local targetPosition = UDim2.new(
			mainPosition.X.Scale,
			mainPosition.X.Offset,
			targetYScale,
			targetYOffset
		)

		clone.Position = startPosition
		clone.BackgroundTransparency = 1
		clone.Size = mainSize

		self:_setTextTransparency(clone, 1)

		local appearDelay = (index - 1) * 0.06

		task.delay(appearDelay, function()
			if not data.isOpen then return end

			local positionTween = TweenService:Create(clone, tween_config, {
				Position = targetPosition,
				BackgroundTransparency = 0
			})
			positionTween:Play()

			self:_animateTextTransparency(clone, 0)
		end)

		table.insert(data.clones, clone)
	end

	if self._autoClose then
		task.delay(auto_close_time, function()
			if data.isOpen then
				self:_closeDropdown(mainButton)
			end
		end)
	end
end

function DropDowner:_closeDropdown(mainButton)
	local data = self._dropdownData[mainButton]
	if not data then return end

	data.isOpen = false

	local mainPosition = mainButton.Position

	for _, clone in data.clones do
		local closeTween = TweenService:Create(clone, tween_close, {
			Position = UDim2.new(
				mainPosition.X.Scale,
				mainPosition.X.Offset,
				mainPosition.Y.Scale,
				mainPosition.Y.Offset
			),
			BackgroundTransparency = 1
		})

		self:_animateTextTransparency(clone, 1)
		closeTween:Play()

		closeTween.Completed:Once(function()
			clone:Destroy()
		end)
	end

	data.clones = {}
end

function DropDowner:_closeAllDropdowns()
	for mainButton, data in self._dropdownData do
		if data.isOpen then
			self:_closeDropdown(mainButton)
		end
	end
end

function DropDowner:_setTextTransparency(element, value)
	if element:IsA("TextButton") or element:IsA("TextLabel") then
		element.TextTransparency = value
	end

	for _, child in element:GetChildren() do
		self:_setTextTransparency(child, value)
	end
end

function DropDowner:_animateTextTransparency(element, targetValue)
	if element:IsA("TextButton") or element:IsA("TextLabel") then
		local textTween = TweenService:Create(element, tween_config, {
			TextTransparency = targetValue
		})
		textTween:Play()
	end

	for _, child in element:GetChildren() do
		self:_animateTextTransparency(child, targetValue)
	end
end

function DropDowner:CloseAll()
	self:_closeAllDropdowns()
end

function DropDowner:Destroy()
	for _, connection in self._connections do connection:Disconnect() end

	for _, data in self._dropdownData do
		for _, clone in data.clones do
			if clone and clone.Parent then
				clone:Destroy()
			end
		end
	end

	table.clear(self._connections)
	table.clear(self._dropdownData)
end

return table.freeze(DropDowner)
